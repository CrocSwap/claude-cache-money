// Merge the object below into ~/.claude/settings.json.
// Everything from the `{` down is strict JSON — do not paste these `//`
// comments into settings.json, only the braces-and-fields portion.
//
// `refreshInterval` makes the statusline re-run every second so the TTL
// counter ticks down live while idle. Without it, the statusline only
// updates on turn boundaries and slash commands.
{
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline.sh",
    "refreshInterval": 1
  }
}
