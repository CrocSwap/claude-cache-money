// Add this to ~/.claude/settings.json
// (merge with your existing settings — don't overwrite)
{
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline.sh"
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/cache-notify.sh",
            "async": true
          }
        ]
      }
    ]
  }
}
